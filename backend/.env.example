# Postgres
DATABASE_URL=postgres://gradex:gradex@localhost:5432/gradex?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# S3-compatible storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=gradexminio
S3_SECRET_KEY=gradexminio
S3_BUCKET=gradex-video
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# Video pipeline config
UPLOAD_URL_EXPIRY_MINUTES=15
PLAYBACK_URL_EXPIRY_MINUTES=5
MAX_UPLOAD_SIZE_BYTES=5368709120

# Auth (fake/dev mode until real JWT auth is built)
AUTH_FAKE_MODE=true

# FFmpeg
FFMPEG_BINARY_PATH=ffmpeg
FFPROBE_BINARY_PATH=ffprobe

# HTTP server
PORT=8080
PLAYBACK_TOKEN_SECRET=changeme-generate-with-openssl-rand-hex-32
